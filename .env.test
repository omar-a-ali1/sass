NODE_ENV=test
PORT=5001

MONGO_URI=mongodb://mongodb_test:27017/sass_test_db

JWT_SECRET=test-jwt-secret-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=test-jwt-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_EXPIRES_IN=15m

SHOW_DOCS=false
SWAGGER_AUTO_SCHEMA=false
SWAGGER_AUTO_RESPONSE=false

EMAIL_DRIVER=console
EMAIL_FROM=test@example.com

LOG_LEVEL=error

# ── Cache ──
CACHE_DRIVER=memory
CACHE_TTL=300
