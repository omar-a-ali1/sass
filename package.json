{
  "name": "sass",
  "version": "1.0.0",
  "description": "A lightweight mini-framework built on Node.js and Express for scalable architectures",
  "main": "server.js",
  "scripts": {
    "test": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles",
    "dev": "cross-env NODE_ENV=development node --watch server.js",
    "start": "cross-env NODE_ENV=production node server.js",
    "generate": "node cli/make.js all",
    "make:controller": "node cli/make.js controller",
    "make:route": "node cli/make.js route",
    "make:service": "node cli/make.js service",
    "make:repository": "node cli/make.js repository",
    "make:validation": "node cli/make.js validation",
    "make:model": "node cli/make.js model",
    "make:all": "node cli/make.js all",
    "routes": "node cli/list-routes.js",
    "models": "node cli/list-models.js",
    "fetch": "node cli/fetch.js",
    "seed": "node cli/seed.js",
    "seed:clean": "node cli/seed.js --clean",
    "make:seeder": "node cli/make.js seeder",
    "sync": "node cli/sync-db.js"
  },
  "author": "OMAR AIT ALI",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "joi": "^18.2.1",
    "joi-to-swagger": "^6.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "mongoose-to-swagger": "^1.5.1",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.21.0",
    "serve-favicon": "^2.5.1",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
