# ── Runtime ──
NODE_ENV=development
APP_URL=http://localhost:5000
PORT=5000
PROJECT_TYPE=jwt                  # 'jwt' (Bearer only), 'cookies' (cookie auth), or 'both'

# ── Database ──
MONGO_URI=mongodb://mongodb_dev:27017/framework_dev
POSTGRES_URI=postgres://user:password@localhost:5432/framework_dev
DB_DRIVER=mongo

# ── Auth / JWT ──
JWT_SECRET=
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d
JWT_RESET_EXPIRES_IN=15m
BCRPT_SALT_SIZE=12

# ── CORS ──
CORS_ORIGIN=*

# ── Docs / Swagger ──
SHOW_DOCS=true
SWAGGER_AUTO_SCHEMA=true       # Auto-generate model schemas in Swagger
SWAGGER_AUTO_RESPONSE=true     # Auto-generate sanitized {Model}Response schemas

# ── Rate Limiting ──
RATE_LIMIT_MAX=9999999
BODY_LIMIT=1mb

# ── Email ──
EMAIL_DRIVER=console
EMAIL_FROM=noreply@example.com
# in case driver enable them 
# EMAIL_HOST=
# EMAIL_PORT=
# EMAIL_USER=
# EMAIL_PASS=
# ── Storage ──
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=storage/uploads
STORAGE_LOCAL_URL=/uploads

# ── Cache ──
CACHE_DRIVER=memory               # 'memory', 'file', or 'redis'
CACHE_TTL=300                     # Default TTL in seconds
# REDIS_URL=redis://localhost:6379
# REDIS_PREFIX=sass:cache:
